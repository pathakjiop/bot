{
  "name": "service-bot",
  "version": "1.0.0",
  "description": "WhatsApp chatbot backend using Bun, Hono, and 2Factor eWhatsApp API",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun build src/server.ts --outdir dist",
    "type-check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.8.0",
    "typescript": "^5.2.2"
  }
}
