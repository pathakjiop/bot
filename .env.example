# =============================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# 2FACTOR eWHATSAPP API  (INSTRUCTION.md §1)
# Get these from your 2Factor dashboard: https://2factor.in
# ---------------------------------------------------------------------------

# Base URL of the 2Factor eWhatsApp API (do not add a trailing slash)
BASE_URL=https://ewhatsapp.2factor.in

# Your WhatsApp Business Account ID
WABA_ID=<your_waba_id>

# The registered phone number ID from 2Factor
PHONE_NUMBER_ID=<your_phone_number_id>

# API key from 2Factor dashboard
API_KEY=<your_api_key>